# Wappa Auth (Google / Apple sosyal giriş)
# Bu dosyayı ".env" olarak kopyala ve değerleri doldur. EXPO_PUBLIC_* değişkenleri
# Expo tarafından otomatik okunur.
#
# UYARI: Bu stack'te EXPO_PUBLIC_* değerleri bundle'a güvenilir inline EDİLMİYOR.
# Bu yüzden asıl değerler game/auth.ts içinde sabit yazılı; buradaki env sadece
# isteğe bağlı override. (Detay için SKILL.md'deki "ÖNEMLİ GOTCHA" bölümüne bak.)

# Wappa panelindeki site key (zorunlu)
EXPO_PUBLIC_WAPPA_KEY={{SITE_KEY}}

# Firebase projendeki OAuth "Web client" ID'si — Google girişi için zorunlu.
# google-services.json içinde client_type: 3 olan oauth_client'ın client_id'si.
EXPO_PUBLIC_WAPPA_GOOGLE_WEB_CLIENT_ID={{GOOGLE_WEB_CLIENT_ID}}

# Wappa API tabanı (opsiyonel — boş bırakılırsa public default kullanılır)
EXPO_PUBLIC_WAPPA_API_BASE_URL={{WAPPA_UI_API_URL}}

# Push bildirimleri (@appaflytech/wappa-notifications) da yukarıdaki EXPO_PUBLIC_WAPPA_KEY
# ve EXPO_PUBLIC_WAPPA_API_BASE_URL değerlerini kullanır. Ancak bu projede EXPO_PUBLIC_*
# bundle'a güvenilir inline edilmediğinden değerler game/auth.ts'te sabit tanımlı ve
# game/notifications.ts oradan okur — env'e ayrıca bir şey eklemene gerek yok.
